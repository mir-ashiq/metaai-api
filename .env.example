# Meta AI API Server Configuration

# Server Settings
PORT=8000
HOST=127.0.0.1

# Meta AI Cookies (Required for authenticated features like video generation)
# Get these from https://www.meta.ai/ after logging in
# Open DevTools (F12) -> Application -> Cookies -> https://www.meta.ai

# Option 1: Set cookies as JSON (Recommended)
META_AI_COOKIES_JSON={"abra_sess":"","datr":"","_js_datr":"","abra_csrf":"","lsd":"","fb_dtsg":""}

# Option 2: Set individual cookies
# META_AI_ABRA_SESS=
# META_AI_ABRA_CSRF=
# META_AI_DATR=
# META_AI_JS_DATR=
# META_AI_LSD=
# META_AI_FB_DTSG=
# META_AI_DPR=
# META_AI_WD=

# Auto Refresh Cookies (keeps cookies fresh)
META_AI_AUTO_REFRESH_COOKIES=true
META_AI_COOKIE_REFRESH_SECONDS=43200

# Proxy Settings (Optional)
# META_AI_PROXY_HTTP=
# META_AI_PROXY_HTTPS=

# Facebook Login (Optional - alternative to cookies)
# META_AI_FB_EMAIL=
# META_AI_FB_PASSWORD=
